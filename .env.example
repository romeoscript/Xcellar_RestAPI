# Email Verification (OTP) Settings
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_HOUR=3
OTP_COOLDOWN_SECONDS=60

# Email Delivery
# The backend is auto-selected: set EMAIL_HOST_USER + EMAIL_HOST_PASSWORD to
# enable real SMTP delivery (OTP & password-reset emails are actually sent).
# Leave them blank to print emails to the console for local development.
# For Gmail, EMAIL_HOST_PASSWORD must be an App Password (not your login).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Xcellar <noreply@xcellar.com>
# Optional: force a specific backend regardless of the credentials above.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Redis (production only). Set REDIS_URL to enable a shared cache and turn on
# login/OTP rate limiting. Leave blank to fall back to local-memory cache with
# rate limiting disabled.
REDIS_URL=
# Object storage for user uploads (production only).
# Set these to route media (KYC docs, parcel images) to S3-compatible storage
# such as MinIO / Cloudflare R2 / S3. Leave AWS_STORAGE_BUCKET_NAME blank to
# keep files on the local filesystem (local/dev). AWS_* are django-storages'
# generic S3 setting names — point AWS_S3_ENDPOINT_URL at your MinIO/R2 server.
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT_URL=
# AWS_S3_REGION_NAME=us-east-1
